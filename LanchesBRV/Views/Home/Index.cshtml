@model HomeViewModel

<partial name="_Carousel" />

<h2> Os preferidos da semana! </h2>

<div class="row">
    @* Renderização dos lanches preferidos utilizando o componente compartilhado de resumo. *@
    @foreach(var lanche in Model.LanchesPreferidos)
    {
        <partial name="_LanchesResumo" for="@lanche" />
    }
</div>
@* A diretiva @model define que a View é fortemente tipada e faz referencia à ViewModel que agrupa Lanche e Categoria *@
@model LancheListViewModel

<div>
    <h1>@Model.CategoriaAtual</h1>
</div>

<div class="container">
<div class="row">

@* Itera sobre a lista de lanches recebida via Model para renderizar o HTML de cada item *@
    @foreach(var lanche in Model.Lanches)
    {
       <div class="col-sm-4 col-md-4 col-lg-4"> 
           <p> <img src="@lanche.ImagemUrl" class="img-fluid"> </p>
           <h3> Preço: @lanche.Preco.ToString("c") </h3>
           <h4> @lanche.Nome </h4>
           <p> @lanche.DescricaoCurta </p>
       </div>    
    }
</div>
</div>